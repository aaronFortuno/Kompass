      { "id": "r3", "group": "Preposició", "content": { "type": "text", "content": "**nach** (_nach Wien_)" } },
      { "id": "r4", "group": "Preposició", "content": { "type": "text", "content": "**seit** (_seit zwei Wochen_)" } },
      { "id": "r5", "group": "Preposició", "content": { "type": "text", "content": "**mit** (_mit meiner Mutter_)" } },
