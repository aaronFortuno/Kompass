      { "id": "4", "label": "ordinal de 100" }
    ]
  },
  "interaction": {
    "type": "typeIn",
    "slots": [
      { "blankId": "1", "placeholder": "-ste" },
      { "blankId": "2", "placeholder": "-ste" },
      { "blankId": "3", "placeholder": "-ste, amb ß" },
      { "blankId": "4", "placeholder": "-ste" }
