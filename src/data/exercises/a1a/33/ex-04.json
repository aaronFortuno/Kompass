      "1": "zwanzigste",
      "2": "einundzwanzigste",
      "3": "dreißigste",
      "4": "hundertste"
    }
  },
  "feedback": {
    "correct": {
      "message": "Perfecte. La regla és mecànica: cardinal + ==_-ste_==. Cap excepció a partir del 20.",
      "references": ["A1a-33"]
    },
    "incorrect": {
      "default": "Revisa: 20 → _zwanzigste_, 21 → _einundzwanzigste_, 30 → _dreißigste_ (amb ß), 100 → _hundertste_. A partir del 20, sempre ==_-ste_==.",
      "byResponse": [
        {
          "match": { "1": "zwanzigte" },
          "message": "Recorda el tall al 20: aquí és ==_-ste_==, no _-te_.",
          "references": ["A1a-33"]
        },
        {
          "match": { "2": "ersteundzwanzigste" },
          "message": "No es converteix _ein-_ en _erst-_ dins del compost. La regla _-ste_ s'aplica al final: _einundzwanzig_ + _ste_ = ==_einundzwanzigste_==.",
          "references": ["A1a-33"]
        },
        {
          "match": { "3": "dreissigste" },
          "message": "En alemany estàndard s'escriu amb ==ß==: _dreißigste_.",
          "references": ["A1a-33"]
        }
      ]
