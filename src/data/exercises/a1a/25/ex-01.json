      { "id": "c2", "group": "Prefix", "content": { "type": "text", "content": "**auf**" } },
      { "id": "c3", "group": "Verb", "content": { "type": "text", "content": "_rufen_ (trucar)" } },
      { "id": "c4", "group": "Prefix", "content": { "type": "text", "content": "**an**" } },
      { "id": "c5", "group": "Verb", "content": { "type": "text", "content": "_sehen_ (mirar la tele)" } },
      { "id": "c6", "group": "Prefix", "content": { "type": "text", "content": "**fern**" } },
      { "id": "c7", "group": "Verb", "content": { "type": "text", "content": "_kaufen_ (fer la compra)" } },
      { "id": "c8", "group": "Prefix", "content": { "type": "text", "content": "**ein**" } }
