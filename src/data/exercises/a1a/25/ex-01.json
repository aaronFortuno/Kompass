    "correct": {
      "message": "Molt bé! Has reconstruït els quatre verbs separables: _==auf==stehen_, _==an==rufen_, _==fern==sehen_, _==ein==kaufen_."
    },
    "incorrect": {
      "default": "Revisa les pistes que dona la traducció catalana: _llevar-se_ → _aufstehen_; _trucar_ → _anrufen_; _mirar la tele_ → _fernsehen_; _fer la compra_ → _einkaufen_."
    }
  }
