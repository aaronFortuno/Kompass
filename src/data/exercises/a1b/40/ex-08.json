      { "id": "q2", "group": "pregunta", "content": { "type": "text", "content": "_**Wem** gehört dieses Handy?_" } },
      { "id": "q3", "group": "pregunta", "content": { "type": "text", "content": "_**Wer** hat dir geholfen?_" } },
      { "id": "q4", "group": "pregunta", "content": { "type": "text", "content": "_**Gefällt** dir München?_" } },
      { "id": "q5", "group": "pregunta", "content": { "type": "text", "content": "_**Wem** antwortest du?_" } },
      { "id": "q6", "group": "pregunta", "content": { "type": "text", "content": "_**Warum** gratulierst du Hans?_" } },
      { "id": "r1", "group": "resposta", "content": { "type": "text", "content": "_==**Meiner Schwester.**==_" } },
      { "id": "r2", "group": "resposta", "content": { "type": "text", "content": "_==**Weil er heute Geburtstag hat.**==_" } },
      { "id": "r3", "group": "resposta", "content": { "type": "text", "content": "_==**Mein Vater hat mir geholfen.**==_" } },
