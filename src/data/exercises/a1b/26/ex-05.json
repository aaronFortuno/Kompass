    "incorrect": {
      "default": "Tres passos: (1) tria l'auxiliar segons el verb (moviment/canvi d'estat → _sein_; la resta → _haben_). (2) Conjuga l'auxiliar segons la persona. (3) El participi és **fix** (gramàtica A1b-27); memoritza'ls del glossari.",
      "byResponse": [
        {
          "match": { "1b": "geessen" },
          "message": "Error d'ortografia: _essen_ fa ==**_gegessen_**== (amb doble _g_ a l'inici: _ge-gessen_)."
        },
        {
          "match": { "2a": "haben" },
          "message": "_gehen_ és moviment → ==**_sein_**==. _wir_ + _sein_ = _**sind**_."
        },
        {
          "match": { "2b": "gegehen" },
          "message": "_gehen_ és irregular: el participi és ==**_gegangen_**== (canvi vocàlic _e → a_), no _gegehen_."
        },
        {
          "match": { "5a": "habt" },
          "message": "_aufstehen_ és canvi d'estat → auxiliar ==**_sein_**==. _ihr_ + _sein_ = _**seid**_."
        },
        {
          "match": { "5b": "aufgestehen" },
          "message": "_aufstehen_ té prefix separable: el _ge-_ va **entre** el prefix i l'arrel → ==**_aufgestanden_**== (amb canvi _e → a_)."
        },
        {
          "match": { "8a": "habe" },
          "message": "_fahren_ és moviment → ==**_sein_**==. _ich_ + _sein_ = _**bin**_."
        },
        {
          "match": { "8b": "gefahrt" },
          "message": "_fahren_ és irregular: participi ==**_gefahren_**== (_-en_, no _-t_)."
        },
        {
