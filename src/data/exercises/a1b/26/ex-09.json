  "feedback": {
    "correct": {
      "message": "==**Fantàstic!**== Has construït una narrativa fluida en Perfekt. Observa l'==**alternança _bin… habe… bin… habe…_**==: _bin aufgestanden / habe getrunken / gegessen / bin gefahren / habe gekauft / habe gesehen / bin gegangen_. Aquesta és exactament la melodia del passat oral alemany.",
      "references": ["A1b-26"]
    },
    "incorrect": {
      "default": "Tres verbs amb ==_sein_== (_aufstehen, fahren, gehen_ — canvi d'estat o moviment); la resta amb ==_haben_==. Tots els participis al final de la seva oració. _Am Samstag_, _Dann_, _Am Abend_ són complements temporals que ocupen V1; l'auxiliar queda en V2 (inversió).",
      "byResponse": [
        {
          "match": { "1a": "habe" },
          "message": "_aufstehen_ és canvi d'estat → ==**_sein_**==. _ich_ + _sein_ = _**bin**_."
        },
        {
          "match": { "4a": "habe" },
          "message": "_fahren_ és moviment → ==**_sein_**==. _ich_ + _sein_ = _**bin**_."
        },
        {
          "match": { "7a": "habe" },
          "message": "_gehen_ és moviment → ==**_sein_**==. _ich_ + _sein_ = _**bin**_."
        },
        {
          "match": { "2a": "bin" },
          "message": "_trinken_ és verb normal → ==**_haben_**==. _ich_ + _haben_ = _**habe**_."
        },
        {
          "match": { "5a": "bin" },
          "message": "_kaufen_ és verb normal → ==**_haben_**==. _ich_ + _haben_ = _**habe**_."
        },
        {
          "match": { "1b": "aufstanden" },
          "message": "Amb prefix separable (_auf-_), el _ge-_ va **entre** el prefix i l'arrel: ==**_aufgestanden_**==."
        },
        {
          "match": { "7b": "gegehen" },
          "message": "_gehen_ és irregular: participi ==**_gegangen_**== (canvi vocàlic _e → a_)."
        },
        {
          "match": { "6b": "gesehn" },
          "message": "Ortografia: ==**_gesehen_**== (amb _-e-_ entre _seh_ i _-en_)."
        },
        {
          "match": { "3": "geessen" },
          "message": "Error d'ortografia: ==**_gegessen_**== (amb doble _g_ a l'inici)."
